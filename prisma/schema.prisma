generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Notebook {
  id              Int              @id @default(autoincrement())
  name            String           @default("Untitled Notebook")
  coverImage      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  notes             Note[]
  diagramKeywords   DiagramKeyword[]
  categories        Category[]
  graphManualEdges     String           @default("[]")
  graphEdgeLabels      String           @default("{}")
  graphNodePositions   String           @default("{}")
}

model Category {
  id         String     @id @default(uuid())
  name       String
  order      Int        @default(0)
  parentId   String?
  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  notebookId Int?
  notebook   Notebook?  @relation(fields: [notebookId], references: [id])
  keywords   DiagramKeyword[]
}

model Note {
  id                Int       @id @default(autoincrement())
  title             String    @default("Untitled")
  titleSetManually  Boolean   @default(false)
  content           String    @default("")
  maxWidth     Int?
  drawingData  String    @default("")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  notebookId   Int?
  notebook     Notebook? @relation(fields: [notebookId], references: [id])
}

model DiagramKeyword {
  id         String    @id @default(uuid())
  text       String
  color      String
  order      Int       @default(0)
  x          Float?
  y          Float?
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  notebookId Int?
  notebook   Notebook? @relation(fields: [notebookId], references: [id])
}

model TermDefinition {
  id         String @id @default(uuid())
  term       String @unique
  definition String
}
